pipeline {
  agent none
  stages {
    stage('Back-end') {
      agent {
        // Updated to official Temurin JDK 21 tag
        docker { image 'maven:3.9.14-eclipse-temurin-21' }
      }
      steps {
        sh 'mvn --version'
      }
    }
    stage('Front-end') {
      agent {
        // This tag is correct; it uses the slim Alpine Linux base
        docker { image 'node:20-alpine' }
      }
      steps {
        sh 'node --version'
      }
    }
  }
}
